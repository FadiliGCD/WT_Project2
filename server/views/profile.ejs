<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= title %></title>
</head>
<body>
  <%- include('partials/nav') %>
  <h1>Profile</h1>
  <p>Username: <%= user.username %></p>
  <p>Email: <%= user.email %></p>
  <p>Saved favourites: <%= favCount %></p>
  <h2>My recipes</h2>
  <ul>
    <% myRecipes.forEach(function (r) { %>
      <li>
        <a href="/recipes/<%= r._id %>"><%= r.title %></a>
        <a href="/recipes/<%= r._id %>/edit">Edit</a>
        <form action="/recipes/<%= r._id %>?_method=DELETE" method="post" style="display:inline;" onsubmit="return confirm('Delete?');">
          <button type="submit">Delete</button>
        </form>
      </li>
    <% }); %>
  </ul>
  <% if (!myRecipes.length) { %><p>You have not published any recipes yet. <a href="/recipes/new">Add one</a>.</p><% } %>
</body>
</html>
